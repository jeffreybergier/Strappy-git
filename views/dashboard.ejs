<!doctype html>
<html lang="en">
  <head>
    <meta charset="utf-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1" />
    <title>Strappy — Jobs Dashboard</title>
    <link
      rel="stylesheet"
      href="https://cdn.jsdelivr.net/npm/bootstrap@3.4.1/dist/css/bootstrap.min.css"
    />
    <style>
      body { padding-top: 70px; padding-bottom: 40px; }
      .step-flow { display: flex; flex-wrap: wrap; align-items: stretch; }
      .step-card { flex: 1 1 220px; min-width: 220px; }
      .step-arrow { display: flex; align-items: center; padding: 0 8px; font-size: 22px; color: #999; }
      .io-label { font-size: 11px; text-transform: uppercase; color: #999; letter-spacing: 1px; }
      .io-list { list-style: none; padding-left: 0; margin: 4px 0 8px; }
      .io-list li { font-family: monospace; font-size: 12px; }
      .io-type { color: #999; }
      .io-src { font-family: sans-serif; font-size: 9px; text-transform: uppercase; letter-spacing: .5px; padding: 0 4px; border-radius: 3px; margin-left: 4px; vertical-align: middle; }
      .io-src-trigger { background: #d9edf7; color: #31708f; }
      .io-src-static { background: #fcf8e3; color: #8a6d3b; }
      .io-src-pass { background: #f5f5f5; color: #999; border: 1px solid #e3e3e3; }
      .io-src-derived { background: #e8e0f5; color: #6f5499; }
      .io-src-receipt { background: #dff0d8; color: #3c763d; }
      .io-src-guided { background: #cdeeeb; color: #27796f; }
      .io-src[title] { cursor: help; }
      .trigger-card { flex: 0 1 200px; min-width: 180px; }
      .trigger-card .panel-heading { background-color: #d9edf7; }
      .runs-table { table-layout: fixed; }
      .runs-table .col-status { width: 110px; }
      .runs-table .col-time { width: 90px; text-align: right; }
      .runs-table td.col-time { font-family: monospace; color: #777; }
      .runs-table .run-row { cursor: pointer; }
      .runs-table .step-row > td { background-color: #fafafa; }
      .transcript-link { margin-left: 6px; white-space: nowrap; }
      .runs-table .step-row-x { cursor: pointer; }
      .runs-table .step-indent { padding-left: 32px; }
      .run-caret { display: inline-block; width: 14px; color: #999; }
      .runs-table .io-section-row > td,
      .runs-table .io-cat-row > td,
      .runs-table .io-row > td,
      .runs-table .io-value-row > td { background-color: #f5f7f9; border-top: none; }
      .runs-table .io-row { cursor: pointer; }
      .io-section-indent { padding-left: 52px; font-size: 11px; text-transform: uppercase; letter-spacing: 1px; color: #555; }
      .io-cat-indent { padding-left: 72px; font-size: 10px; text-transform: uppercase; letter-spacing: .5px; color: #999; }
      .io-key-indent { padding-left: 92px; font-family: monospace; font-size: 12px; }
      .io-value-indent { padding-left: 92px; }
      pre.io-value { white-space: pre-wrap; word-break: break-word; max-height: 260px; overflow: auto;
        margin: 2px 0 6px; padding: 6px 8px; font-size: 12px; background: #fff; border: 1px solid #e3e3e3; border-radius: 3px; }
    </style>
  </head>
  <body>
    <nav class="navbar navbar-inverse navbar-fixed-top">
      <div class="container">
        <div class="navbar-header">
          <span class="navbar-brand">Strappy · Jobs Dashboard</span>
        </div>
        <p class="navbar-text navbar-right">pi.dev + OpenRouter</p>
      </div>
    </nav>

    <div class="container">
      <h2>Jobs <small>live · auto-refreshing</small></h2>
      <div id="runs"><p class="text-muted">Loading runs…</p></div>
      <noscript>
        <p class="text-muted">Live runs need JavaScript. Raw data: <code>/api/runs</code>.</p>
      </noscript>

      <h2>Process Map <small>ISO 9001-style process maps</small></h2>
      <% jobs.forEach(function (job) { %>
        <div class="panel panel-default">
          <div class="panel-heading">
            <strong><%= job.name %></strong>
            <span class="label label-primary"><%= job.trigger %></span>
            <div class="text-muted"><%= job.description %></div>
          </div>
          <div class="panel-body">
            <div class="step-flow">
              <% if (job.triggerInputs && job.triggerInputs.length) { %>
                <div class="panel panel-info step-card trigger-card">
                  <div class="panel-heading"><strong>Trigger</strong></div>
                  <div class="panel-body">
                    <p class="small"><code><%= job.trigger %></code></p>
                    <div class="io-label">Outputs</div>
                    <ul class="io-list">
                      <% job.triggerInputs.forEach(function (io) { %>
                        <li><%= io.key %> <span class="io-type">:<%= io.type %></span></li>
                      <% }); %>
                    </ul>
                  </div>
                </div>
                <div class="step-arrow">&rarr;</div>
              <% } %>
              <% job.steps.forEach(function (step, i) { %>
                <% if (i > 0) { %><div class="step-arrow">&rarr;</div><% } %>
                <div class="panel panel-default step-card">
                  <div class="panel-heading"><strong><%= step.name %></strong></div>
                  <div class="panel-body">
                    <p class="small"><%= step.description %></p>
                    <div class="io-label">Inputs</div>
                    <ul class="io-list">
                      <% step.inputs.forEach(function (io) { %>
                        <li><%= io.key %> <span class="io-type">:<%= io.type %></span><% if (io.source && io.source !== "step") { %> <span class="io-src io-src-<%= io.source %>"<% if (io.source === "static" && step.systemPrompt) { %> title="<%= step.systemPrompt %>"<% } %>><%= io.source %></span><% } %></li>
                      <% }); %>
                    </ul>
                    <div class="io-label">Outputs</div>
                    <ul class="io-list">
                      <% step.outputs.forEach(function (io) { %>
                        <li><%= io.key %> <span class="io-type">:<%= io.type %></span><% if (io.source && io.source !== "step") { %> <span class="io-src io-src-<%= io.source %>"><%= io.source %></span><% } %><% if (io.guidance) { %> <span class="io-src io-src-guided" title="<%= io.guidance %>">guided</span><% } %></li>
                      <% }); %>
                    </ul>
                  </div>
                </div>
              <% }); %>
            </div>
          </div>
        </div>
      <% }); %>
    </div>

    <script>
      (function () {
        "use strict";
        const POLL_MS = 60000;
        const TICK_MS = 1000;
        const RUN_BADGE = {
          queued: "default", pending: "default", running: "info",
          succeeded: "success", failed: "danger", skipped: "warning",
        };

        const container = document.getElementById("runs");
        if (!container) throw new Error("[dashboard] #runs container is missing");

        // Category order + labels per direction; the source key matches StepIO.source
        // and the io-src-* badge classes, so the run hierarchy reuses the map's legend.
        const INPUT_GROUPS = [
          ["trigger", "Trigger constants"], ["static", "Static"],
          ["step", "From previous step"], ["pass", "Passed through"],
        ];
        const OUTPUT_GROUPS = [
          ["step", "Produced"], ["derived", "Derived"],
          ["pass", "Passed through"], ["receipt", "Receipts"],
        ];

        const openRuns = new Set();
        const openSteps = new Set();
        const openIos = new Set();
        let jobsIndex = {};
        let runs = [];

        function badge(status) {
          return RUN_BADGE[status] || "default";
        }

        function esc(value) {
          const map = { "&": "&amp;", "<": "&lt;", ">": "&gt;", '"': "&quot;" };
          return String(value == null ? "" : value).replace(/[&<>"]/g, (c) => map[c]);
        }

        function fmtDuration(ms) {
          if (typeof ms !== "number" || !isFinite(ms) || ms < 0) return "";
          const s = Math.round(ms / 1000);
          if (s < 60) return s + "s";
          return Math.floor(s / 60) + "m " + (s % 60) + "s";
        }

        function stepRuntime(sr) {
          if (sr.startedAt && sr.finishedAt) return fmtDuration(Date.parse(sr.finishedAt) - Date.parse(sr.startedAt));
          if (sr.status === "running" && sr.startedAt) return fmtDuration(Date.now() - Date.parse(sr.startedAt));
          return "—";
        }

        function runRuntime(run) {
          const end = run.finishedAt ? Date.parse(run.finishedAt) : Date.now();
          return fmtDuration(end - Date.parse(run.startedAt));
        }

        function stepContract(run, sr) {
          const job = jobsIndex[run.jobId] || {};
          return job[sr.stepId] || { name: sr.stepId, inputs: [], outputs: [] };
        }

        function stepLabel(run, sr) {
          return stepContract(run, sr).name || sr.stepId;
        }

        function noteHtml(sr) {
          if (!sr.note) return "";
          return ' <span class="text-muted small">' + esc(sr.note) + "</span>";
        }

        // A link to the step's rendered LLM transcript, when one was recorded.
        // The stored value is a repo-relative file path (data/sessions/<file>);
        // the basename maps to the /sessions static route the server mounts.
        function transcriptHtml(sr) {
          const path = sr.execution && sr.execution.transcriptPath;
          if (!path) return "";
          const file = String(path).split("/").pop();
          return ' <a class="transcript-link small" href="/sessions/' + esc(encodeURIComponent(file)) +
            '" target="_blank" rel="noopener" title="' + esc(path) + '">📄 transcript</a>';
        }

        function statusCell(status) {
          return '<td class="col-status"><span class="label label-' + badge(status) + '">' + esc(status) + "</span></td>";
        }

        function runRow(run, open) {
          const caret = '<span class="run-caret">' + (open ? "▾" : "▸") + "</span> ";
          const name = caret + "<code>" + esc(run.id) + '</code> <span class="text-muted">' + esc(run.jobId) + "</span>";
          return (
            '<tr class="run-row" data-run="' + esc(run.id) + '">' +
            statusCell(run.status) +
            '<td class="col-name">' + name + "</td>" +
            '<td class="col-time">' + esc(runRuntime(run)) + "</td>" +
            "</tr>"
          );
        }

        function hasValues(bag) {
          return !!bag && Object.keys(bag).length > 0;
        }

        function canExpandStep(sr) {
          return hasValues(sr.inputs) || hasValues(sr.outputs);
        }

        function stepKey(run, sr) {
          return run.id + "::" + sr.stepId;
        }

        function ioKey(run, sr, direction, key) {
          return stepKey(run, sr) + "::" + direction + "::" + key;
        }

        function stepRow(run, sr, i) {
          const can = canExpandStep(sr);
          const caret = '<span class="run-caret">' + (can ? (openSteps.has(stepKey(run, sr)) ? "▾" : "▸") : "") + "</span> ";
          const attrs = can ? ' class="step-row step-row-x" data-step="' + esc(stepKey(run, sr)) + '"' : ' class="step-row"';
          return (
            "<tr" + attrs + ">" +
            statusCell(sr.status) +
            '<td class="col-name step-indent">' + caret + (i + 1) + ". " + esc(stepLabel(run, sr)) + noteHtml(sr) + transcriptHtml(sr) + "</td>" +
            '<td class="col-time">' + esc(stepRuntime(sr)) + "</td>" +
            "</tr>"
          );
        }

        function stepRows(run, sr, i) {
          const head = stepRow(run, sr, i);
          if (!canExpandStep(sr) || !openSteps.has(stepKey(run, sr))) return head;
          const contract = stepContract(run, sr);
          return head +
            groupRows(run, sr, "input", "Inputs", sr.inputs, contract.inputs) +
            groupRows(run, sr, "output", "Outputs", sr.outputs, contract.outputs);
        }

        // Renders one direction (Inputs/Outputs): a section header, then a labelled
        // sub-group per source that has values, then each value's collapsible row.
        // Keys with no declared source land under "Other" so nothing is dropped.
        function groupRows(run, sr, direction, label, values, contract) {
          if (!hasValues(values)) return "";
          const groups = direction === "input" ? INPUT_GROUPS : OUTPUT_GROUPS;
          const source = sourceMap(contract);
          const seen = new Set();
          let html = sectionRow(label);
          groups.forEach((g) => {
            const keys = Object.keys(values).filter((k) => source[k] === g[0]);
            keys.forEach((k) => seen.add(k));
            if (keys.length) html += catRow(g[1]) + keys.map((k) => ioRows(run, sr, direction, k, ioOf(contract, k), values[k])).join("");
          });
          const rest = Object.keys(values).filter((k) => !seen.has(k));
          if (rest.length) html += catRow("Other") + rest.map((k) => ioRows(run, sr, direction, k, ioOf(contract, k), values[k])).join("");
          return html;
        }

        function ioRows(run, sr, direction, key, io, value) {
          const k = ioKey(run, sr, direction, key);
          const open = openIos.has(k);
          return open ? ioRow(k, open, key, io) + valueRow(value) : ioRow(k, open, key, io);
        }

        function ioRow(k, open, key, io) {
          const caret = '<span class="run-caret">' + (open ? "▾" : "▸") + "</span> ";
          const type = io ? ' <span class="io-type">:' + esc(io.type) + "</span>" : "";
          return (
            '<tr class="io-row" data-io="' + esc(k) + '">' +
            '<td class="col-status"></td>' +
            '<td class="col-name io-key-indent">' + caret + "<code>" + esc(key) + "</code>" + type + sourceBadge(io) + descHtml(io) + "</td>" +
            '<td class="col-time"></td>' +
            "</tr>"
          );
        }

        function valueRow(value) {
          return '<tr class="io-value-row"><td colspan="3" class="io-value-indent"><pre class="io-value">' + esc(formatValue(value)) + "</pre></td></tr>";
        }

        function formatValue(value) {
          return typeof value === "string" ? value : JSON.stringify(value);
        }

        function sourceBadge(io) {
          if (!io || !io.source || io.source === "step") return "";
          return ' <span class="io-src io-src-' + esc(io.source) + '">' + esc(io.source) + "</span>";
        }

        function descHtml(io) {
          if (!io || !io.description) return "";
          return ' <span class="text-muted small">' + esc(io.description) + "</span>";
        }

        function sectionRow(label) {
          return '<tr class="io-section-row"><td class="col-status"></td><td class="col-name io-section-indent"><strong>' + esc(label) + '</strong></td><td class="col-time"></td></tr>';
        }

        function catRow(label) {
          return '<tr class="io-cat-row"><td class="col-status"></td><td class="col-name io-cat-indent">' + esc(label) + '</td><td class="col-time"></td></tr>';
        }

        function sourceMap(contract) {
          const map = {};
          (contract || []).forEach((io) => { map[io.key] = io.source; });
          return map;
        }

        function ioOf(contract, key) {
          return (contract || []).find((io) => io.key === key) || null;
        }

        function runRows(run) {
          const open = openRuns.has(run.id);
          if (!open) return runRow(run, open);
          return runRow(run, open) + run.stepRuns.map((sr, i) => stepRows(run, sr, i)).join("");
        }

        function render() {
          if (!runs.length) {
            container.innerHTML = '<p class="text-muted">No runs yet.</p>';
            return;
          }
          const head = '<thead><tr><th class="col-status">Status</th><th>Name</th><th class="col-time">Runtime</th></tr></thead>';
          container.innerHTML =
            '<table class="table table-hover runs-table">' + head + "<tbody>" + runs.map(runRows).join("") + "</tbody></table>";
        }

        function flip(set, id) {
          if (set.has(id)) set.delete(id);
          else set.add(id);
          render();
        }

        // Most-specific row first: an io/step/run row is its own <tr>, so the
        // deepest open level toggles without disturbing its ancestors.
        function toggle(ev) {
          if (ev.target.closest("a")) return; // let links (e.g. transcript) act, not toggle the row
          const io = ev.target.closest(".io-row");
          if (io) return flip(openIos, io.getAttribute("data-io"));
          const step = ev.target.closest(".step-row-x");
          if (step) return flip(openSteps, step.getAttribute("data-step"));
          const run = ev.target.closest(".run-row");
          if (run) return flip(openRuns, run.getAttribute("data-run"));
        }

        async function fetchJson(url) {
          const res = await fetch(url, { headers: { Accept: "application/json" } });
          if (!res.ok) throw new Error("[dashboard.fetchJson] " + url + " -> " + res.status);
          return res.json();
        }

        function indexJobs(jobs) {
          const map = {};
          jobs.forEach((job) => {
            map[job.id] = {};
            job.steps.forEach((s) => { map[job.id][s.id] = { name: s.name, inputs: s.inputs || [], outputs: s.outputs || [] }; });
          });
          return map;
        }

        function byNewest(a, b) {
          return Date.parse(b.startedAt) - Date.parse(a.startedAt);
        }

        async function refresh() {
          try {
            runs = (await fetchJson("/api/runs")).sort(byNewest);
            render();
          } catch (err) {
            console.error("[dashboard.refresh]", err);
          }
        }

        async function init() {
          try {
            jobsIndex = indexJobs(await fetchJson("/api/jobs"));
          } catch (err) {
            console.error("[dashboard.init]", err);
          }
          container.addEventListener("click", toggle);
          await refresh();
          setInterval(refresh, POLL_MS);
          setInterval(render, TICK_MS);
        }

        init();
      })();
    </script>
  </body>
</html>
