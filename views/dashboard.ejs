<!doctype html>
<html lang="en">
  <head>
    <meta charset="utf-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1" />
    <title>enil-cocoa — Jobs Dashboard</title>
    <link
      rel="stylesheet"
      href="https://cdn.jsdelivr.net/npm/bootstrap@3.4.1/dist/css/bootstrap.min.css"
    />
    <style>
      body { padding-top: 70px; padding-bottom: 40px; }
      .step-flow { display: flex; flex-wrap: wrap; align-items: stretch; }
      .step-card { flex: 1 1 220px; min-width: 220px; }
      .step-arrow { display: flex; align-items: center; padding: 0 8px; font-size: 22px; color: #999; }
      .io-label { font-size: 11px; text-transform: uppercase; color: #999; letter-spacing: 1px; }
      .io-list { list-style: none; padding-left: 0; margin: 4px 0 8px; }
      .io-list li { font-family: monospace; font-size: 12px; }
      .io-type { color: #999; }
      .io-src { font-family: sans-serif; font-size: 9px; text-transform: uppercase; letter-spacing: .5px; padding: 0 4px; border-radius: 3px; margin-left: 4px; vertical-align: middle; }
      .io-src-trigger { background: #d9edf7; color: #31708f; }
      .io-src-static { background: #fcf8e3; color: #8a6d3b; }
      .io-src-pass { background: #f5f5f5; color: #999; border: 1px solid #e3e3e3; }
      .io-src-derived { background: #e8e0f5; color: #6f5499; }
      .io-src-receipt { background: #dff0d8; color: #3c763d; }
      .io-src-guided { background: #cdeeeb; color: #27796f; }
      .io-src[title] { cursor: help; }
      .trigger-card { flex: 0 1 200px; min-width: 180px; }
      .trigger-card .panel-heading { background-color: #d9edf7; }
      .runs-table { table-layout: fixed; }
      .runs-table .col-status { width: 110px; }
      .runs-table .col-time { width: 90px; text-align: right; }
      .runs-table td.col-time { font-family: monospace; color: #777; }
      .runs-table .run-row { cursor: pointer; }
      .runs-table .step-row > td { background-color: #fafafa; }
      .runs-table .step-indent { padding-left: 32px; }
      .run-caret { display: inline-block; width: 14px; color: #999; }
    </style>
  </head>
  <body>
    <nav class="navbar navbar-inverse navbar-fixed-top">
      <div class="container">
        <div class="navbar-header">
          <span class="navbar-brand">enil-cocoa · Jobs Dashboard</span>
        </div>
        <p class="navbar-text navbar-right">pi.dev + OpenRouter</p>
      </div>
    </nav>

    <div class="container">
      <h2>Jobs <small>live · auto-refreshing</small></h2>
      <div id="runs"><p class="text-muted">Loading runs…</p></div>
      <noscript>
        <p class="text-muted">Live runs need JavaScript. Raw data: <code>/api/runs</code>.</p>
      </noscript>

      <h2>Process Map <small>ISO 9001-style process maps</small></h2>
      <% jobs.forEach(function (job) { %>
        <div class="panel panel-default">
          <div class="panel-heading">
            <strong><%= job.name %></strong>
            <span class="label label-primary"><%= job.trigger %></span>
            <div class="text-muted"><%= job.description %></div>
          </div>
          <div class="panel-body">
            <div class="step-flow">
              <% if (job.triggerInputs && job.triggerInputs.length) { %>
                <div class="panel panel-info step-card trigger-card">
                  <div class="panel-heading"><strong>Trigger</strong></div>
                  <div class="panel-body">
                    <p class="small"><code><%= job.trigger %></code></p>
                    <div class="io-label">Outputs</div>
                    <ul class="io-list">
                      <% job.triggerInputs.forEach(function (io) { %>
                        <li><%= io.key %> <span class="io-type">:<%= io.type %></span></li>
                      <% }); %>
                    </ul>
                  </div>
                </div>
                <div class="step-arrow">&rarr;</div>
              <% } %>
              <% job.steps.forEach(function (step, i) { %>
                <% if (i > 0) { %><div class="step-arrow">&rarr;</div><% } %>
                <div class="panel panel-default step-card">
                  <div class="panel-heading"><strong><%= step.name %></strong></div>
                  <div class="panel-body">
                    <p class="small"><%= step.description %></p>
                    <div class="io-label">Inputs</div>
                    <ul class="io-list">
                      <% step.inputs.forEach(function (io) { %>
                        <li><%= io.key %> <span class="io-type">:<%= io.type %></span><% if (io.source && io.source !== "step") { %> <span class="io-src io-src-<%= io.source %>"<% if (io.source === "static" && step.systemPrompt) { %> title="<%= step.systemPrompt %>"<% } %>><%= io.source %></span><% } %></li>
                      <% }); %>
                    </ul>
                    <div class="io-label">Outputs</div>
                    <ul class="io-list">
                      <% step.outputs.forEach(function (io) { %>
                        <li><%= io.key %> <span class="io-type">:<%= io.type %></span><% if (io.source && io.source !== "step") { %> <span class="io-src io-src-<%= io.source %>"><%= io.source %></span><% } %><% if (io.guidance) { %> <span class="io-src io-src-guided" title="<%= io.guidance %>">guided</span><% } %></li>
                      <% }); %>
                    </ul>
                  </div>
                </div>
              <% }); %>
            </div>
          </div>
        </div>
      <% }); %>
    </div>

    <script>
      (function () {
        "use strict";
        const POLL_MS = 3000;
        const TICK_MS = 1000;
        const RUN_BADGE = {
          queued: "default", pending: "default", running: "info",
          succeeded: "success", failed: "danger", skipped: "warning",
        };

        const container = document.getElementById("runs");
        if (!container) throw new Error("[dashboard] #runs container is missing");

        const expanded = new Set();
        let stepNames = {};
        let runs = [];

        function badge(status) {
          return RUN_BADGE[status] || "default";
        }

        function esc(value) {
          const map = { "&": "&amp;", "<": "&lt;", ">": "&gt;", '"': "&quot;" };
          return String(value == null ? "" : value).replace(/[&<>"]/g, (c) => map[c]);
        }

        function fmtDuration(ms) {
          if (typeof ms !== "number" || !isFinite(ms) || ms < 0) return "";
          const s = Math.round(ms / 1000);
          if (s < 60) return s + "s";
          return Math.floor(s / 60) + "m " + (s % 60) + "s";
        }

        function stepRuntime(sr) {
          if (sr.startedAt && sr.finishedAt) return fmtDuration(Date.parse(sr.finishedAt) - Date.parse(sr.startedAt));
          if (sr.status === "running" && sr.startedAt) return fmtDuration(Date.now() - Date.parse(sr.startedAt));
          return "—";
        }

        function runRuntime(run) {
          const end = run.finishedAt ? Date.parse(run.finishedAt) : Date.now();
          return fmtDuration(end - Date.parse(run.startedAt));
        }

        function stepLabel(run, sr) {
          const names = stepNames[run.jobId] || {};
          return names[sr.stepId] || sr.stepId;
        }

        function noteHtml(sr) {
          if (!sr.note) return "";
          return ' <span class="text-muted small">' + esc(sr.note) + "</span>";
        }

        function statusCell(status) {
          return '<td class="col-status"><span class="label label-' + badge(status) + '">' + esc(status) + "</span></td>";
        }

        function runRow(run, open) {
          const caret = '<span class="run-caret">' + (open ? "▾" : "▸") + "</span> ";
          const name = caret + "<code>" + esc(run.id) + '</code> <span class="text-muted">' + esc(run.jobId) + "</span>";
          return (
            '<tr class="run-row" data-run="' + esc(run.id) + '">' +
            statusCell(run.status) +
            '<td class="col-name">' + name + "</td>" +
            '<td class="col-time">' + esc(runRuntime(run)) + "</td>" +
            "</tr>"
          );
        }

        function stepRow(run, sr, i) {
          return (
            '<tr class="step-row">' +
            statusCell(sr.status) +
            '<td class="col-name step-indent">' + (i + 1) + ". " + esc(stepLabel(run, sr)) + noteHtml(sr) + "</td>" +
            '<td class="col-time">' + esc(stepRuntime(sr)) + "</td>" +
            "</tr>"
          );
        }

        function runRows(run) {
          const open = expanded.has(run.id);
          if (!open) return runRow(run, open);
          return runRow(run, open) + run.stepRuns.map((sr, i) => stepRow(run, sr, i)).join("");
        }

        function render() {
          if (!runs.length) {
            container.innerHTML = '<p class="text-muted">No runs yet.</p>';
            return;
          }
          const head = '<thead><tr><th class="col-status">Status</th><th>Name</th><th class="col-time">Runtime</th></tr></thead>';
          container.innerHTML =
            '<table class="table table-hover runs-table">' + head + "<tbody>" + runs.map(runRows).join("") + "</tbody></table>";
        }

        function toggle(ev) {
          const head = ev.target.closest(".run-row");
          if (!head) return;
          const id = head.getAttribute("data-run");
          if (expanded.has(id)) expanded.delete(id);
          else expanded.add(id);
          render();
        }

        async function fetchJson(url) {
          const res = await fetch(url, { headers: { Accept: "application/json" } });
          if (!res.ok) throw new Error("[dashboard.fetchJson] " + url + " -> " + res.status);
          return res.json();
        }

        function indexStepNames(jobs) {
          const map = {};
          jobs.forEach((job) => {
            map[job.id] = {};
            job.steps.forEach((s) => { map[job.id][s.id] = s.name; });
          });
          return map;
        }

        function byNewest(a, b) {
          return Date.parse(b.startedAt) - Date.parse(a.startedAt);
        }

        async function refresh() {
          try {
            runs = (await fetchJson("/api/runs")).sort(byNewest);
            render();
          } catch (err) {
            console.error("[dashboard.refresh]", err);
          }
        }

        async function init() {
          try {
            stepNames = indexStepNames(await fetchJson("/api/jobs"));
          } catch (err) {
            console.error("[dashboard.init]", err);
          }
          container.addEventListener("click", toggle);
          await refresh();
          setInterval(refresh, POLL_MS);
          setInterval(render, TICK_MS);
        }

        init();
      })();
    </script>
  </body>
</html>
