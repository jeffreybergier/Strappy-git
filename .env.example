# GitHub machine account (strappy) — classic PAT with `repo` scope
# (add `workflow` only if the agent edits files under .github/workflows/).
# Used for clone, push branch, and open PR.
GITHUB_TOKEN=

# OpenRouter API key — create one at https://openrouter.ai/keys
# Pi reads this via the "$OPENROUTER_API_KEY" reference in config/models.json
OPENROUTER_API_KEY=

# Default open-source model id (any model from config/models.json)
OPENROUTER_MODEL=meta-llama/llama-3.3-70b-instruct

# Web server port for the jobs dashboard
PORT=3000

# SQLite database path (gitignored; auto-created and seeded on first run)
DB_PATH=data/strappy.sqlite

# SECURITY: only issues/PRs/comments opened by these GitHub users trigger jobs.
# Comma-separated, case-insensitive. EMPTY = nobody (fail closed).
STRAPPY_USER_WHITELIST=jeffreybergier

# Where repos are cloned per job: <tempDir>/jobs/<uuid>/<reponame>
STRAPPY_TEMP_DIR=/strappy-temp

# Poll interval for new issues (ms)
POLL_INTERVAL_MS=60000

# Commit identity for the strappy bot
STRAPPY_GIT_NAME=strappy
STRAPPY_GIT_EMAIL=strappy@users.noreply.github.com
